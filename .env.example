# Copy to .env and fill in. For production, use Postgres:
# DATABASE_URL="postgresql://user:pass@host:5432/heruni?schema=public"
DATABASE_URL="file:./dev.db"

# NextAuth
NEXTAUTH_SECRET="change-me-in-production-use-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Optional: Cloudflare Turnstile (Sprint 4 — public submission captcha)
TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""
