# --- Database ---
# Local dev with docker-compose.yml:
DATABASE_URL="postgresql://heruni:heruni@localhost:5432/heruni?schema=public"
#
# Railway (auto-injected by the attached Postgres plugin):
#   DATABASE_URL=${{ Postgres.DATABASE_URL }}

# --- NextAuth ---
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET="change-me-in-production"
# In Railway, set to your public URL (e.g. https://heruni-dict.up.railway.app)
NEXTAUTH_URL="http://localhost:3000"

# --- Seeding ---
# Dev seeds two editor accounts with predictable passwords. In production,
# leave SEED_DEFAULT_EDITORS unset (or "false") so those accounts aren't
# created. Supply one real admin via BOOTSTRAP_ADMIN_* on first deploy.
SEED_DEFAULT_EDITORS="true"
BOOTSTRAP_ADMIN_EMAIL=""
BOOTSTRAP_ADMIN_PASSWORD=""

# --- Cloudflare Turnstile (Sprint 4 — public submission captcha) ---
TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# --- Site ---
# Used for sitemap / canonical URLs. Without it, sitemap falls back to
# NEXTAUTH_URL and finally to http://localhost:3000.
SITE_URL=""

# --- AI inference engine (v2 Sprint 3) ---
# Anthropic API key for Claude calls. Without this set, the AI inference
# engine disables itself gracefully — admin UI shows a "no API key" state.
ANTHROPIC_API_KEY=""
# Default model. Opus 4.7 for launch (§3 of v2 brief); Sonnet 4.6 for
# throughput passes (~5× cheaper).
AI_MODEL="claude-opus-4-7"
# Effort (Opus-tier only): low | medium | high | max. "high" is the brief's
# recommended default for correctness-first work.
AI_EFFORT="high"
