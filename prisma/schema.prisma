// Heruni Dict — data model (Sprint 1 §5 of the brief).
//
// Provider: PostgreSQL (Railway deploy target, per brief §4). Array fields
// from the brief (meaning_hy text[], see_also int[], root_sequence int[]) are
// stored as JSON strings for now and accessed through the parseList /
// parseInts helpers in src/lib/prisma.ts. A v1.1 migration can convert them
// to native text[] / int[] columns without any app-layer changes — the
// queries used (String { contains }) also work on Postgres directly.
//
// For local dev without a Postgres instance, see docker-compose.yml.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// The 162 SSB entries. 39 length-1 + 86 length-2 + 37 length-3 = 162.
model Root {
  id         Int      @id @default(autoincrement())
  token      String   @unique // ա, բ, ար, իկա …
  length     Int // 1 | 2 | 3 — indexed
  meaningHy  String // JSON string — array of Armenian glosses
  meaningEn  String // JSON string — array of English glosses
  symbol     String? // ⊕ ⊖ ⊗ ⊙ …
  seeAlso    String   @default("[]") // JSON array of Root.id ints
  bookPage   Int // 111 | 112 | 113
  notesHy    String?
  notesEn    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([length])
  @@index([token])
}

/// Decomposed word entries.
///
/// v2 (§3.1 of Heruni_Dict_v2_Sprint_Plan.docx) adds editorial fields for
/// classical etymology, historical usage, related words, book references,
/// and links into the new Pattern / AiDraft tables. All new columns are
/// nullable so v1 rows continue to render after migration.
model Word {
  id             Int      @id @default(autoincrement())
  wordHy         String   @unique
  transliteration String
  decomposition  String // canonical dotted form: "ի • շ • խ • ան"
  rootSequence   String // JSON array of Root.id ints, in order
  suffix         String? // e.g. "ություն"
  meaningHy      String
  meaningEn      String
  category       String // people | animals | astronomy | nature | names | geography | abstract | tools | other
  source         String
  confidence     Int // 1=book, 2=editor-certain, 3=editor-tentative
  status         String   @default("draft") // draft | review | published
  slug           String   @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // --- v2 editorial fields (all nullable; v1 rows keep rendering) ------
  classicalEtymologyHy String? // Armenian prose, Աճառյան / classical view
  classicalEtymologyEn String? // English translation of the above
  classicalSourceRef   String? // JSON array of strings: ["Աճառյան HAB vol.II p.243", …]
  firstAttestation     String? // "5th c., Ագաթանգեղոս"
  usagePeriod          String? // grabar | middle-armenian | ashkharhabar | modern | pan-historic
  historicalUsageHy    String?
  historicalUsageEn    String?
  culturalNotesHy      String?
  culturalNotesEn      String?
  relatedWordIds       String? // JSON array of Word.id ints
  heruniBookRefs       String? // JSON array of Source.id ints
  patternId            Int?
  aiDraftId            Int?

  pattern Pattern? @relation(fields: [patternId], references: [id])

  @@index([status])
  @@index([category])
  @@index([slug])
  @@index([patternId])
  @@index([usagePeriod])
}

/// Heruni book citations (§3.2). One row per book page that analyses a
/// specific word — editors link words into this table via Word.heruniBookRefs.
model Source {
  id              Int      @id @default(autoincrement())
  bookPage        Int // 1..321
  chapter         String? // "2.7", "3.1"
  excerptHy       String
  excerptEn       String?
  mentionedWords  String // JSON array of strings, for indexing candidate words
  imageUrl        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([bookPage])
}

/// Rhetorical templates distilled from Heruni's ~80 worked reconstructions
/// (§3.3). Each row is a reusable shape the AI inference engine can follow.
model Pattern {
  id           Int      @id @default(autoincrement())
  code         String   @unique // possessive_owner, descended_from, …
  nameHy       String
  nameEn       String
  templateHy   String // "{ADJ} {NOUN}-ի տեր"
  templateEn   String // "owner of the {ADJ} {NOUN}"
  descriptionHy String?
  descriptionEn String?
  exampleWords String   @default("[]") // JSON array of Word.id ints
  appliesWhen  String   @default("{}") // JSON object: triggering conditions
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  words  Word[]
  drafts AiDraft[]

  @@index([code])
}

/// Editor-curated word lists (§4.2): named collections like "Governance
/// terms", "Kinship", "Armenian toponyms" — used as targets for bulk
/// AI-drafting. Membership is a JSON array of Word.id (matching the rest
/// of v2's string-as-array storage convention).
model WordList {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  wordIds     String   @default("[]") // JSON array of Word.id ints
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

/// Audit trail for AI-generated reconstructions (§3.4). Every Claude call
/// writes a row here; editors review and publish from the admin queue.
model AiDraft {
  id             Int      @id @default(autoincrement())
  wordId         Int
  patternId      Int?
  kind           String   @default("heruni") // heruni | classical
  promptUsed     String
  model          String // "claude-opus-4-7" etc.
  rawResponse    String
  draftMeaningHy String?
  draftMeaningEn String?
  confidence     Int? // 1..5, self-reported by model
  reviewedById   Int? // FK Editor.id
  reviewStatus   String   @default("pending") // pending | approved | edited | rejected
  finalMeaningHy String?
  finalMeaningEn String?
  editorNotes    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  pattern Pattern? @relation(fields: [patternId], references: [id])

  @@index([wordId])
  @@index([reviewStatus])
  @@index([kind])
}

/// Public submissions.
model Submission {
  id                    Int      @id @default(autoincrement())
  wordHy                String
  proposedDecomposition String?
  proposedMeaningHy     String?
  proposedMeaningEn     String?
  submitterEmail        String?
  status                String   @default("pending") // pending | approved | rejected | merged
  createdAt             DateTime @default(now())
  mergedWordId          Int?

  @@index([status])
}

/// Admin users.
model Editor {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String
  displayName  String
  role         String   @default("editor") // editor | admin
  createdAt    DateTime @default(now())
}

/// Audit log of all edits.
model AuditLog {
  id        Int      @id @default(autoincrement())
  actorId   Int?
  action    String // e.g. "root.update", "word.create", "submission.approve"
  entity    String // "root" | "word" | "submission" | "editor"
  entityId  Int?
  diff      String? // JSON string of before/after
  createdAt DateTime @default(now())

  @@index([entity, entityId])
  @@index([createdAt])
}
